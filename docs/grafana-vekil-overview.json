{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (provider, endpoint, status) (rate(vekil_requests_total[$__rate_interval]))",
          "legendFormat": "{{provider}} {{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Request rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider, endpoint) (rate(vekil_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95 {{provider}} {{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "p95 latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (provider, public_model, direction) (rate(vekil_tokens_total[$__rate_interval]))",
          "legendFormat": "{{provider}} {{public_model}} {{direction}}",
          "refId": "A"
        }
      ],
      "title": "Token rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (provider, endpoint, reason) (rate(vekil_retries_total[$__rate_interval]))",
          "legendFormat": "{{provider}} {{endpoint}} {{reason}}",
          "refId": "A"
        },
        {
          "expr": "sum by (provider, endpoint, code) (rate(vekil_upstream_errors_total[$__rate_interval]))",
          "legendFormat": "errors {{provider}} {{endpoint}} {{code}}",
          "refId": "B"
        }
      ],
      "title": "Retries and upstream errors",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "vekil",
    "prometheus"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Vekil Overview",
  "uid": "vekil-overview",
